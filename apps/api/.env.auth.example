# Variáveis de Ambiente para Autenticação
# Adicione ao arquivo .env na raiz do projeto

# ======================
# JWT Configuration
# ======================
JWT_SECRET=your-super-secret-jwt-key-change-in-production-use-256-bit-key
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-also-change-in-production
JWT_REFRESH_EXPIRATION=7d

# ======================
# Password Security
# ======================
PASSWORD_SALT_ROUNDS=12
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL_CHARS=true

# ======================
# Session Management
# ======================
SESSION_EXPIRATION=86400
SESSION_EXTENDED_EXPIRATION=2592000
MAX_SESSIONS_PER_USER=5

# ======================
# Refresh Token Settings
# ======================
REFRESH_TOKEN_EXPIRATION=604800
REFRESH_TOKEN_EXTENDED_EXPIRATION=2592000
MAX_REFRESH_TOKENS_PER_USER=10

# ======================
# Rate Limiting
# ======================
LOGIN_RATE_LIMIT_TTL=300000
LOGIN_RATE_LIMIT_ATTEMPTS=5
REGISTER_RATE_LIMIT_TTL=3600000
REGISTER_RATE_LIMIT_ATTEMPTS=3
PASSWORD_RESET_RATE_LIMIT_TTL=3600000
PASSWORD_RESET_RATE_LIMIT_ATTEMPTS=3
EMAIL_VERIFICATION_RATE_LIMIT_TTL=1800000
EMAIL_VERIFICATION_RATE_LIMIT_ATTEMPTS=3

# ======================
# Security Features
# ======================
ENABLE_RECAPTCHA=false
ENABLE_TWO_FACTOR=false
ENABLE_ACCOUNT_LOCKOUT=true
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION=900000
ENABLE_PASSWORD_HISTORY=false
PASSWORD_HISTORY_SIZE=5

# ======================
# Email Configuration
# ======================
ENABLE_EMAIL_VERIFICATION=true
EMAIL_VERIFICATION_TOKEN_EXPIRATION=86400000
PASSWORD_RESET_TOKEN_EXPIRATION=3600000

# ======================
# Cookie Settings
# ======================
COOKIE_MAX_AGE=86400000

# ======================
# CORS Settings
# ======================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200,https://yourdomain.com

# ======================
# Redis Configuration (para sessões e cache)
# ======================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ======================
# Environment
# ======================
NODE_ENV=development