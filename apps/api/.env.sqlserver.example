# ================================
# CONFIGURAÇÃO SQL SERVER (LEGADO)
# ================================

# Configurações de conexão com SQL Server para consulta de clientes
SQL_SERVER_HOST=localhost
SQL_SERVER_PORT=1433
SQL_SERVER_USER=sa
SQL_SERVER_PASSWORD=SuaSenhaAqui
SQL_SERVER_DATABASE=LaboratorioDB

# Configurações de segurança
SQL_SERVER_ENCRYPT=false
SQL_SERVER_TRUST_CERT=true

# ================================
# OBSERVAÇÕES
# ================================

# 1. Ajuste o nome do banco de dados (SQL_SERVER_DATABASE) conforme seu sistema
# 2. A tabela de clientes deve ter a seguinte estrutura:
#    COLUNAS OBRIGATÓRIAS:
#    - cod_cliente (ID único - INT PRIMARY KEY)
#    - nome_cliente (VARCHAR)
#    - cpf_cliente (VARCHAR)
#
#    COLUNAS OPCIONAIS (usadas se disponíveis):
#    - identidade_cliente (RG)
#    - nascimento_cliente (DATE)
#    - sexo_cliente (CHAR)
#    - fone_cliente (VARCHAR)
#    - celular_cliente (VARCHAR)
#    - email_cliente (VARCHAR)
#    - endereco_cliente (VARCHAR)
#    - endereco_numero_cliente (VARCHAR)
#    - complemento_cliente (VARCHAR)
#    - bairro_cliente (VARCHAR)
#    - cidade_cliente (VARCHAR)
#    - estado_cliente (VARCHAR)
#    - cep_cliente (VARCHAR)
#    - nome_mae (VARCHAR)
#    - nome_pai (VARCHAR)
#    - nome_social (VARCHAR)
#    - tipo_sang (VARCHAR)
#    - data_cadastro (DATETIME)
#
# 3. O sistema foi configurado para a estrutura real da tabela cliente
# 4. Nem todos os campos são obrigatórios - o sistema se adapta aos dados disponíveis
