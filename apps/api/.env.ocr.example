# 🔍 Configuração de OCR APIs
# Configure as APIs que deseja usar para comparação de OCR

# AWS Textract
# Obtenha em: https://aws.amazon.com/console
# IAM → Users → Create User → AmazonTextractFullAccess
AWS_REGION=sa-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Google Cloud Vision
# Obtenha em: https://console.cloud.google.com
# APIs & Services → Credentials → Create API Key
GOOGLE_VISION_API_KEY=your-google-vision-api-key

# Azure Computer Vision
# Obtenha em: https://portal.azure.com
# Create Resource → Computer Vision → Keys and Endpoint
AZURE_VISION_API_KEY=your-azure-vision-key
AZURE_VISION_ENDPOINT=https://your-resource.cognitiveservices.azure.com
