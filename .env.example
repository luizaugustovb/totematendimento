# ==============================================
# CONFIGURAÇÕES GERAIS
# ==============================================
NODE_ENV=development
PORT=3000

# ==============================================
# BANCO DE DADOS
# ==============================================
DATABASE_URL=postgresql://laboratorio:lab123456@localhost:5432/laboratorio_db

# ==============================================
# REDIS E FILAS
# ==============================================
REDIS_URL=redis://localhost:6379

# ==============================================
# AUTENTICAÇÃO E SEGURANÇA
# ==============================================
JWT_SECRET=sua_chave_secreta_muito_forte_aqui_mude_em_producao
JWT_EXPIRATION=7d
BCRYPT_SALT_ROUNDS=12

# ==============================================
# UPLOADS E ARQUIVOS
# ==============================================
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# ==============================================
# OCR - GOOGLE VISION
# ==============================================
GOOGLE_VISION_API_KEY=
GOOGLE_VISION_ENDPOINT=https://vision.googleapis.com/v1

# ==============================================
# IA - CLAUDE
# ==============================================
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-sonnet-20240229
CLAUDE_MAX_TOKENS=4096

# ==============================================
# VIICIO API
# ==============================================
VIICIO_API_URL=https://api.viicio.com.br
VIICIO_API_TOKEN=
VIICIO_ENABLED=true

# ==============================================
# EXECUÇÃO DE SCRIPTS PYTHON
# ==============================================
PYTHON_SCRIPTS_PATH=./python-scripts
PYTHON_TIMEOUT_SECONDS=60
PYTHON_EXECUTABLE=python3

# ==============================================
# LOGS
# ==============================================
LOG_LEVEL=info
LOG_FILE_ENABLED=true
LOG_FILE_PATH=./logs

# ==============================================
# CONFIGURAÇÕES DO TOTEM
# ==============================================
TOTEM_MODE=true
TOTEM_TIMEOUT_MINUTES=10
TOTEM_AUTO_ADVANCE=true

# ==============================================
# CONFIGURAÇÕES DE INTEGRAÇÃO
# ==============================================
LEGACY_SYSTEM_API_URL=
LEGACY_SYSTEM_API_TOKEN=
INTEGRATION_ENABLED=false

# ==============================================
# CONFIGURAÇÕES DE DESENVOLVIMENTO
# ==============================================
DEBUG_MODE=true
MOCK_OCR=false
MOCK_AI=false
MOCK_VIICIO=false

# ==============================================
# CONFIGURAÇÕES DE CORS
# ==============================================
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# ==============================================
# CONFIGURAÇÕES DE RATE LIMITING
# ==============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100